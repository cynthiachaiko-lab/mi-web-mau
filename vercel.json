{
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/login",   "dest": "/login.html" },
    { "src": "/admin",   "dest": "/admin.html" },
    { "src": "/",        "dest": "/index.html" }
  ]
}
